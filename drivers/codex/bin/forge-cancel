#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks so the script works when invoked via ~/.codex/bin/forge-cancel.
SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  LINK_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
  TARGET_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$TARGET_PATH" == /* ]] && SOURCE_PATH="$TARGET_PATH" || SOURCE_PATH="${LINK_DIR}/${TARGET_PATH}"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
LIB_PATH="${ROOT_DIR}/drivers/codex/lib.sh"
STATE_DIR="$(pwd)/.forge"

source "$LIB_PATH"

session_id="${1:-}"
if [[ "${session_id:-}" == "--help" ]] || [[ "${session_id:-}" == "-h" ]]; then
  echo "Usage: forge-cancel [SESSION_ID]" >&2
  exit 1
fi

if [[ ! -d "$STATE_DIR" ]]; then
  echo "Error: .forge does not exist in this project." >&2
  exit 1
fi

session_id="$(forge_choose_session "$STATE_DIR" "$session_id")"
loop_state="${STATE_DIR}/loop-state.${session_id}.md"

if [[ ! -f "$loop_state" ]]; then
  echo "Error: Session ${session_id} does not exist." >&2
  exit 1
fi

rm -f "$loop_state"
echo "Cancelled Forge Codex driver session ${session_id}."
echo "Preserved: .forge/forge-state.${session_id}.md"
